{
  "vendor": "shelly",
  "native_topics": {
    "patterns": [
      {
        "pattern": "shellies/x/{tenant_slug}/sh/{device_id}/telemetry/{native_path}",
        "native_path_mode": "rest"
      }
    ],
    "mappings": [
      {
        "native_path": "relay/0/power",
        "target_key": "power",
        "type": "float"
      },
      {
        "native_path": "relay/0/energy",
        "target_key": "energy",
        "type": "float"
      },
      {
        "native_path": "relay/0",
        "target_key": "output",
        "type": "boolean",
        "value_map": {
          "on": true,
          "off": false
        }
      },
      {
        "native_path": "temperature",
        "target_key": "temperature",
        "type": "float"
      },
      {
        "native_path": "temperature_f",
        "target_key": "temperature_f",
        "type": "float"
      },
      {
        "native_path": "overtemperature",
        "target_key": "overtemperature",
        "type": "int"
      }
    ]
  },
  "inbound": {
    "mappings": [
      {
        "payload_path": "temperature",
        "target_key": "temperature",
        "type": "float"
      },
      {
        "payload_path": "apower",
        "target_key": "power",
        "type": "float"
      },
      {
        "payload_path": "voltage",
        "target_key": "voltage",
        "type": "float"
      },
      {
        "payload_path": "current",
        "target_key": "current",
        "type": "float"
      },
      {
        "payload_path": "output",
        "target_key": "output",
        "type": "boolean"
      }
    ]
  },
  "meta": {
    "source": "mqtt_router",
    "adapter": "json_mapping"
  }
}
